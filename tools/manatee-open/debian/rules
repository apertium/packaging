#!/usr/bin/make -f
# -*- makefile -*-

#export DH_VERBOSE=1
export DH_OPTIONS
export LC_ALL=C.UTF-8

%:
	dh $@ --fail-missing --parallel --with autoreconf

override_dh_auto_configure:
	dh_auto_configure -- --with-pcre

override_dh_auto_install:
	dh_auto_install
	find $(CURDIR) -type f -name '*.pyc' -delete
	find $(CURDIR) -type f -name '*.pyo' -delete
	find $(CURDIR) -type f -name '*.la' -delete

override_dh_auto_test:
	# Do nothing for now
